# Environnement
NODE_ENV=development

# Serveur
PORT=5000

# URL du client frontend (pour CORS)
# En développement: http://localhost:5173 (Vite) ou http://localhost:3000 (React)
# En production: https://votredomaine.com
CLIENT_URL=http://localhost:5173

# Base de données MongoDB
MONGODB_URI_DEV=mongodb://localhost:27017/tontitrack_dev
MONGODB_URI_TEST=mongodb://localhost:27017/tontitrack_test
MONGODB_URI_PROD=mongodb+srv://username:password@cluster.mongodb.net/tontitrack

# JWT Secrets (générez avec: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Sécurité
BCRYPT_ROUNDS=10

# Rate Limiting (requêtes par fenêtre de 15 minutes)
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5