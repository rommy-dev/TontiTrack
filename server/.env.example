# ── Environnement ─────────────────────────────────────────────────────────────
# Valeurs possibles : development | test | production
NODE_ENV=development

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=5000

# ── CORS — URL du frontend autorisé ──────────────────────────────────────────
# Dev local (sans Docker) : http://localhost:5173
# Dev avec Docker         : http://localhost:3000
# Production              : https://votre-domaine.com
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# env.js sélectionne automatiquement l'URI selon NODE_ENV :
#
# Format Atlas : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI_DEV=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tontitrack_dev

# ── JWT — Secrets de signature des tokens ─────────────────────────────────────
# OBLIGATOIRE — Générer avec : openssl rand -base64 32
# Les deux doivent être différents et d'au moins 32 caractères
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Durée de vie des tokens (format ms / vercel/ms)
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Nombre de rounds bcrypt (10 en dev, 12 en prod)
BCRYPT_ROUNDS=10

# ── Rate Limiting (requêtes par fenêtre de 15 minutes) ────────────────────────
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5