# GitHub Container Registry
GITHUB_USERNAME=rommy-dev

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tontitrack

# JWT
JWT_ACCESS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyy

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Application
NODE_ENV=production
PORT=5000
CLIENT_URL=https://tontitrack.com

BCRYPT_ROUNDS=12
API_RATE_LIMIT=100
AUTH_RATE_LIMIT=5