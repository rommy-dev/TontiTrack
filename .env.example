# Votre username GitHub (pour les images ghcr.io)
GITHUB_USERNAME=your-github-username

# ── MongoDB Production (pour docker-compose.prod.yml) ────────────────────────
# Utilisateur root MongoDB (créé au premier démarrage du container)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me-strong-root-password

# Utilisateur applicatif MongoDB (créé par mongo-init.js)
MONGO_USER=tontitrack_user
MONGO_PASSWORD=change-me-strong-app-password

# ── Secrets JWT (partagés prod/dev via ce fichier si pas de server/.env) ─────
# Générer avec : openssl rand -base64 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── URL du client (pour CORS côté serveur en production) ─────────────────────
CLIENT_URL=https://votre-domaine.com
