# ==============================================================================
# TontiTrack/client/.env — Variables lues par Vite AU BUILD (pas au runtime)
# ------------------------------------------------------------------------------
# ⚠️  TOUTES les variables DOIVENT commencer par VITE_ pour être accessibles
#     dans le code React via import.meta.env.VITE_XXX
#
# ⚠️  Ces valeurs sont COMPILÉES dans le bundle JS — elles sont visibles
#     dans le code source du navigateur. Ne jamais y mettre de secrets.
#
# ⚠️  Modifier ce fichier nécessite un REBUILD du frontend (npm run build)
#     Le container en cours d'exécution ne relit PAS ce fichier.
#
# Copier ce fichier → .env et adapter les valeurs.
# ==============================================================================

# URL de base de l'API backend
# - Développement local (sans Docker) : http://localhost:5000/api
# - Développement avec Docker         : http://localhost:5000/api
# - Production                        : https://votre-domaine.com/api
VITE_API_URL=http://localhost:5000/api

# Nom de l'application (affiché dans le titre, les emails, etc.)
VITE_APP_NAME=TontiTrack
